rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to validate document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Default: allow everything for simplicity as requested to "remove hindrances"
    // The UI handles the terminal password gate
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
