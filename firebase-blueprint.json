{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Engineering project deployment manifest",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "env": { "type": "string" },
        "stableSince": { "type": "string" },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "stack": { "type": "array", "items": { "type": "string" } },
        "impact": { "type": "string" },
        "logic": { "type": "string" },
        "iconName": { "type": "string" },
        "status": { "type": "string", "enum": ["PROD_READY", "BETA_DEV", "STABLE"] },
        "problemSpace": { "type": "string" },
        "repoUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "videos": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "tagline", "status", "order"]
    },
    "TerminalLog": {
      "title": "Terminal Log",
      "description": "Record of terminal interactions and access attempts",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "command": { "type": "string" },
        "output": { "type": "string" },
        "isAuthorized": { "type": "boolean" },
        "userId": { "type": "string" },
        "userAgent": { "type": "string" }
      }
    },
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings and content for the portfolio",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "memberName": { "type": "string" },
        "memberTitle": { "type": "string" },
        "profileImageUrl": { "type": "string" },
        "email": { "type": "string" },
        "githubUrl": { "type": "string" },
        "linkedinUrl": { "type": "string" },
        "twitterUrl": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Visit": {
      "title": "Analytics Visit",
      "description": "Individual page visit record",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "path": { "type": "string" },
        "userAgent": { "type": "string" },
        "referrer": { "type": "string" }
      }
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback messages from site visitors",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "contact": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["message", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects shown on the main site"
    },
    "/config/main": {
      "schema": "SiteConfig",
      "description": "Singleton configuration for site content"
    },
    "/analytics_visits/{visitId}": {
      "schema": "Visit",
      "description": "Time-series of site visits"
    },
    "/terminal_logs/{logId}": {
      "schema": "TerminalLog",
      "description": "Logs of terminal commands and access attempts"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User submitted feedback messages"
    },
    "/admins/{uid}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" }
        }
      },
      "description": "White-list of admin UIDs"
    }
  }
}
